# === FREE DEFAULT: Google Gemini + HuggingFace local embeddings ===
# Get a free Google API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# LLM Configuration (defaults to free Google Gemini)
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash

# Embedding Configuration (defaults to free local HuggingFace)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === OPTIONAL: Paid providers (uncomment to use) ===
# OPENAI_API_KEY=sk-your-key-here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ANTHROPIC_API_KEY=sk-ant-your-key-here
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514

# Vector Store
CHROMA_PERSIST_DIR=./chroma_db

# RAG Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5
